{
  "name": "@ehrbase-ui/observability",
  "version": "0.0.0",
  "private": true,
  "description": "Pino application logger + OTel SDK + Pino-OTLP transport + PHI redaction + health/ready check aggregator. Framework-agnostic — apps register transports / providers at startup.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./log": "./src/log/index.ts",
    "./otel": "./src/otel/index.ts",
    "./otel/redact": "./src/otel/redact.ts",
    "./health": "./src/health/index.ts"
  },
  "dependencies": {
    "@ehrbase-ui/db-platform": "workspace:*",
    "@ehrbase-ui/valkey": "workspace:*",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "drizzle-orm": "1.0.0-rc.4-273829f",
    "pino": "10.3.1",
    "pino-opentelemetry-transport": "3.0.0"
  },
  "devDependencies": {
    "@ehrbase-ui/config-tsconfig": "workspace:*",
    "@types/node": "25.9.1",
    "vitest": "4.1.7"
  }
}
