{
  "name": "@ehrbase-ui/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The missing open-source UI for EHRbase. Clinical workspace, dynamic openEHR forms, AQL query builder.",
  "license": "Apache-2.0",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "paraglide:compile": "pnpm -F @ehrbase-ui/i18n run paraglide:compile",
    "paraglide:check": "pnpm -F @ehrbase-ui/i18n run paraglide:check",
    "db:generate": "drizzle-kit generate --config=drizzle.auth.config.ts && drizzle-kit generate --config=drizzle.demographic.config.ts && drizzle-kit generate --config=drizzle.audit.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.auth.config.ts && drizzle-kit migrate --config=drizzle.demographic.config.ts && drizzle-kit migrate --config=drizzle.audit.config.ts",
    "db:studio:auth": "drizzle-kit studio --config=drizzle.auth.config.ts",
    "db:studio:demographic": "drizzle-kit studio --config=drizzle.demographic.config.ts",
    "db:studio:audit": "drizzle-kit studio --config=drizzle.audit.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "storybook": "STORYBOOK=true storybook dev -p 6006",
    "storybook:build": "STORYBOOK=true storybook build",
    "lint": "eslint .",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1054.0",
    "@aws-sdk/lib-storage": "3.1054.0",
    "@better-auth/sso": "1.6.11",
    "@ehrbase-ui/config-tsconfig": "workspace:*",
    "@ehrbase-ui/demographic-core": "workspace:*",
    "@ehrbase-ui/i18n": "workspace:*",
    "@ehrbase-ui/openehr-flat": "workspace:*",
    "@ehrbase-ui/openehr-its-rest": "workspace:*",
    "@ehrbase-ui/openehr-rm": "workspace:*",
    "@ehrbase-ui/openehr-web-template": "workspace:*",
    "@ehrbase-ui/term-adapter-generic-fhir": "workspace:*",
    "@ehrbase-ui/term-adapter-snowstorm": "workspace:*",
    "@ehrbase-ui/term-core": "workspace:*",
    "@ehrbase-ui/valkey": "workspace:*",
    "@fontsource-variable/geist": "5.2.9",
    "@hookform/resolvers": "5.4.0",
    "@inlang/paraglide-js": "2.18.1",
    "@noble/ciphers": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-query-devtools": "5.100.14",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.14",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.26",
    "@tanstack/router-plugin": "1.168.11",
    "arctic": "3.7.0",
    "better-auth": "1.6.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.3.0",
    "drizzle-orm": "1.0.0-rc.4-273829f",
    "ioredis": "5.11.0",
    "lucide-react": "1.16.0",
    "next-themes": "0.4.6",
    "nitro": "npm:nitro-nightly@3.0.260522-beta",
    "pino": "10.3.1",
    "pino-opentelemetry-transport": "3.0.0",
    "postgres": "3.4.9",
    "radix-ui": "1.4.3",
    "rate-limiter-flexible": "11.1.0",
    "react": "19.2.6",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@chromatic-com/storybook": "5.2.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.1.7",
    "axe-core": "4.11.4",
    "drizzle-kit": "1.0.0-rc.4-273829f",
    "jsdom": "29.1.1",
    "pino-pretty": "13.1.3",
    "shadcn": "4.8.2",
    "storybook": "10.4.1",
    "vite": "7.3.3",
    "vitest": "4.1.7",
    "vitest-axe": "0.1.0"
  }
}
