# Dependencies
node_modules/
.pnpm-store/

# Turborepo cache + log directory (per-workspace + at repo root)
.turbo/

# TypeScript project-references build info (per-package)
*.tsbuildinfo

# TanStack Start / Nitro / Vite build output (per-app, but the patterns
# are unanchored so they match in any directory)
.output/
.nitro/
.vinxi/
.tanstack/
dist/
build/

# Paraglide compiled output (regenerated on build) — lives under apps/web
# per the monorepo layout (ADR-0030).
apps/web/src/paraglide/

# orval generated output (regenerated on demand) — lives in the openehr
# REST client package per ADR-0030 / ADR-0032.
packages/openehr-its-rest/src/generated/
# Sanitized OAS copies (spec defaults stripped) consumed by orval — transient
# build artefact; the pristine vendored specs live in openapi/*.yaml.
packages/openehr-its-rest/openapi/.sanitized/

# TanStack Router generated route tree
apps/web/src/routeTree.gen.ts

# Test artefacts (any package may generate them)
coverage/
playwright-report/
playwright/.cache/
test-results/
.vitest-cache/

# Storybook static build
storybook-static/

# Env files — never commit
.env
.env.local
.env.*.local
*.env

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
#.idea/
.vscode/
*.swp
*.swo
.fleet/

# Sourcemaps generated for release artefacts (uploaded out-of-band, never served)
*.map
