{
  "name": "ehrbase-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The missing open-source UI for EHRbase. Clinical workspace, dynamic openEHR forms, AQL query builder.",
  "license": "Apache-2.0",
  "author": "The EHRbase UI Contributors",
  "homepage": "https://github.com/rubentalstra/ehrbase-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubentalstra/ehrbase-ui.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.3.0",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.13",
    "@tanstack/router-plugin": "1.168.11",
    "nitro": "npm:nitro-nightly@3.0.260522-beta",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "7.3.3"
  },
  "//": "pnpm settings live in pnpm-workspace.yaml (onlyBuiltDependencies, minimumReleaseAge, etc)."
}
