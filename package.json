{
  "name": "ehrbase-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The missing open-source UI for EHRbase. Clinical workspace, dynamic openEHR forms, AQL query builder.",
  "license": "Apache-2.0",
  "author": "The EHRbase UI Contributors",
  "homepage": "https://github.com/rubentalstra/ehrbase-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubentalstra/ehrbase-ui.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.4.0",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "paraglide:compile": "node scripts/paraglide-compile.mjs",
    "paraglide:check": "pnpm paraglide:compile && node scripts/paraglide-check.mjs",
    "api:gen": "orval --config ./orval.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "storybook": "STORYBOOK=true storybook dev -p 6006",
    "storybook:build": "STORYBOOK=true storybook build",
    "lint": "eslint .",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@hookform/resolvers": "5.4.0",
    "@inlang/paraglide-js": "2.18.1",
    "@tailwindcss/vite": "4.3.0",
    "arctic": "3.7.0",
    "drizzle-orm": "1.0.0-rc.4-273829f",
    "ioredis": "5.11.0",
    "postgres": "3.4.9",
    "rate-limiter-flexible": "11.1.0",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-query-devtools": "5.100.14",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.14",
    "@tanstack/router-plugin": "1.168.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.3.0",
    "lucide-react": "1.16.0",
    "next-themes": "0.4.6",
    "nitro": "npm:nitro-nightly@3.0.260522-beta",
    "pino": "10.3.1",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@chromatic-com/storybook": "5.2.1",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint-react/eslint-plugin": "5.8.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.1.7",
    "axe-core": "4.11.4",
    "drizzle-kit": "1.0.0-rc.4-273829f",
    "eslint": "10.4.0",
    "eslint-plugin-jsx-a11y-x": "0.2.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "orval": "8.13.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "shadcn": "4.8.0",
    "storybook": "10.4.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "7.3.3",
    "vitest": "4.1.7",
    "vitest-axe": "0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{md,json,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "//": "pnpm settings live in pnpm-workspace.yaml (onlyBuiltDependencies, minimumReleaseAge, etc)."
}
