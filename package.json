{
  "name": "ehrbase-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo root. The deployable app lives at apps/web (per ADR-0030). Workspace packages live at packages/*. This root only holds turbo orchestration + cross-package tooling (ESLint, Prettier, commitlint, husky).",
  "license": "Apache-2.0",
  "author": "The EHRbase UI Contributors",
  "homepage": "https://github.com/rubentalstra/ehrbase-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubentalstra/ehrbase-ui.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "turbo run dev --filter @ehrbase-ui/web",
    "build": "turbo run build",
    "preview": "turbo run preview --filter @ehrbase-ui/web",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --filter @ehrbase-ui/web",
    "lint": "turbo run lint",
    "e2e": "turbo run e2e --filter @ehrbase-ui/web",
    "storybook": "turbo run storybook --filter @ehrbase-ui/web",
    "storybook:build": "turbo run storybook:build --filter @ehrbase-ui/web",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "paraglide:compile": "pnpm --filter @ehrbase-ui/i18n paraglide:compile",
    "paraglide:check": "pnpm --filter @ehrbase-ui/i18n paraglide:check",
    "regen": "turbo run regen",
    "regen:check": "turbo run regen:check",
    "db:generate": "pnpm --filter @ehrbase-ui/web db:generate",
    "db:migrate": "pnpm --filter @ehrbase-ui/web db:migrate",
    "db:studio:auth": "pnpm --filter @ehrbase-ui/web db:studio:auth",
    "seed:templates": "bash scripts/dev/seed-templates.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.1",
    "@ehrbase-ui/config-eslint": "workspace:*",
    "@eslint-react/eslint-plugin": "5.8.6",
    "@eslint/js": "10.0.1",
    "eslint": "10.4.0",
    "eslint-plugin-jsx-a11y-x": "0.2.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "turbo": "2.9.15",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{md,json,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "//": "pnpm settings live in pnpm-workspace.yaml (onlyBuiltDependencies, minimumReleaseAge, etc)."
}
