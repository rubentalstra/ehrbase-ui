# Environment variables consumed by the ehrbase-ui app and docker-compose.
# Copy to `.env.local` for local development; never commit a real `.env`.
# docs/architecture.md §19.

# ─── Compose profiles ───────────────────────────────────────────────────
# `demo` activates the keycloak-seed-demo-users one-shot container (4 demo
# accounts, one per realm role; passwords in docs/demo-accounts.md). LEAVE
# UNSET in production — production must never seed these credentials.
COMPOSE_PROFILES=demo

# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# ─── EHRbase upstream ───────────────────────────────────────────────────
EHRBASE_URL=http://localhost:8080/ehrbase/rest/openehr/v1

# ─── Keycloak (OIDC) ────────────────────────────────────────────────────
# Dual-URL handling (docs/architecture.md §5.4). The browser is redirected to
# the EXTERNAL issuer URL; server-side token + JWKS calls use the INTERNAL one.
# Keycloak's KC_HOSTNAME pins the issuer so validation agrees on both sides.
# In local `pnpm dev` (no container) both point at localhost:8180; in compose
# the internal URL is http://keycloak:8080/realms/ehrbase (set in the ui svc).
KEYCLOAK_ISSUER_URL=http://localhost:8180/realms/ehrbase
KEYCLOAK_INTERNAL_ISSUER_URL=http://localhost:8180/realms/ehrbase
KEYCLOAK_CLIENT_ID=ehrbase-ui
# Replace with the realm-configured confidential-client secret. Required.
KEYCLOAK_CLIENT_SECRET=dev-only-rotate-in-prod
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Valkey (sessions + audit hash-chain head + rate-limit store) ───────
VALKEY_URL=redis://localhost:6379
# In production, also set VALKEY_PASSWORD.

# ─── Auth database (docs/architecture.md §5; ADR-0028, ADR-0029) ────────
# Better Auth's user / session / account / verification + admin / org / sso
# plugin tables. Runtime writes use the auth_writer role (full CRUD on the
# Better Auth tables only); migrations use auth_owner.
AUTH_DB_URL=postgres://auth_writer:auth_writer@localhost:5432/auth
AUTH_DB_OWNER_URL=postgres://auth_owner:auth_owner@localhost:5432/auth
# Server-side secret used by Better Auth to sign cookies + tokens. Generate
# via: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32
# Public base URL for the app; Better Auth uses this for callback URLs.
BETTER_AUTH_URL=http://localhost:3000
# SSO plugin: Keycloak OIDC provider config (the Keycloak realm we already
# import). Better Auth fetches the OIDC discovery doc from {issuer}/.well-known.
SSO_KEYCLOAK_PROVIDER_ID=keycloak
SSO_KEYCLOAK_ISSUER=http://localhost:8180/realms/ehrbase
SSO_KEYCLOAK_CLIENT_ID=ehrbase-ui
SSO_KEYCLOAK_CLIENT_SECRET=dev-only-rotate-in-prod

# ─── Audit database (docs/architecture.md §14; ADR-0012, ADR-0013) ──────
# The app's first owned DB. Runtime writes use the least-privilege
# audit_writer role (INSERT + SELECT only); migrations use audit_owner.
# A standalone URL so prod can target a physically separate managed Postgres.
AUDIT_DB_URL=postgres://audit_writer:audit_writer@localhost:5432/audit
AUDIT_DB_OWNER_URL=postgres://audit_owner:audit_owner@localhost:5432/audit
# Retention-purge role — the ONE role granted DELETE on audit_events plus
# UPDATE of `s3_archived_at` (M4 — ADR-0027). The append-only trigger has a
# narrow exception for this role only; every other column stays immutable.
AUDIT_RETENTION_DB_URL=postgres://audit_retention:audit_retention@localhost:5432/audit
# Redundant durable NDJSON sink for audit events (file on a persistent volume).
AUDIT_LOG_PATH=/var/log/ehrbase-ui/audit.ndjson
# HMAC-SHA256 key for subject pseudonymization (docs/architecture.md §14.4).
# Generate via:  openssl rand -hex 32
AUDIT_PSEUDONYM_SECRET=replace-me-with-openssl-rand-hex-32

# ─── M4 audit governance (architecture.md §14.6, §14.7, §19.1) ──────────
# Cold-tier archive for the retention purge. Pick one:
#   seaweedfs — open-source dev default; best-effort (SeaweedFS issue #8350)
#   aws       — production WORM-compliant
#   none      — no-op (logs only); for unit tests + dev without a cold tier
COLD_STORAGE_PROVIDER=none
COLD_STORAGE_BUCKET=audit-archive
COLD_STORAGE_REGION=us-east-1
COLD_STORAGE_ENDPOINT=http://localhost:8333
COLD_STORAGE_ACCESS_KEY=dev-access-key
COLD_STORAGE_SECRET_KEY=dev-secret-key
COLD_STORAGE_OBJECT_LOCK_MODE=COMPLIANCE
# Warm-tier retention per policy (days). Defaults match §14.7. Override per
# the deployment's national clinical-records law.
AUDIT_RETENTION_DAYS_CLINICAL_RECORD=7300
AUDIT_RETENTION_DAYS_AUDIT_LOG=1825
AUDIT_RETENTION_DAYS_AUTH_LOG=365
AUDIT_RETENTION_DAYS_APP_LOG=90
AUDIT_RETENTION_DAYS_SESSION=2
AUDIT_PURGE_BATCH_SIZE=100
# Nitro scheduled-task crons (ADR-0026). UTC. Default 03:00 + 04:00 daily.
AUDIT_INTEGRITY_CRON='0 3 * * *'
AUDIT_PURGE_CRON='0 4 * * *'
# Kill-switch — both tasks no-op when set to `true`.
AUDIT_TASKS_DISABLED=false
# Optional POST target for the integrity job on chain break (alerts the DPO).
# Leave unset to log-only (M5 observability picks the structured line up).
# DPO_ALERT_WEBHOOK=https://alerts.example.invalid/dpo

# ─── Session timeouts (defaults from docs/architecture.md §5.10) ────────
SESSION_IDLE_TIMEOUT_SECONDS=900       # 15 minutes
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200 # 12 hours

# ─── OpenTelemetry (Milestone 7) ────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ehrbase-ui
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_LOG_LEVEL=warn
