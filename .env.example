# Environment variables consumed by the ehrbase-ui app and docker-compose.
# Copy to `.env.local` for local development; never commit a real `.env`.
# docs/architecture.md §19.

# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# ─── EHRbase upstream ───────────────────────────────────────────────────
EHRBASE_URL=http://localhost:8080/ehrbase/rest/openehr/v1

# ─── Keycloak (OIDC) ────────────────────────────────────────────────────
# Dual-URL handling (docs/architecture.md §5.4). The browser is redirected to
# the EXTERNAL issuer URL; server-side token + JWKS calls use the INTERNAL one.
# Keycloak's KC_HOSTNAME pins the issuer so validation agrees on both sides.
# In local `pnpm dev` (no container) both point at localhost:8180; in compose
# the internal URL is http://keycloak:8080/realms/ehrbase (set in the ui svc).
KEYCLOAK_ISSUER_URL=http://localhost:8180/realms/ehrbase
KEYCLOAK_INTERNAL_ISSUER_URL=http://localhost:8180/realms/ehrbase
KEYCLOAK_CLIENT_ID=ehrbase-ui
# Replace with the realm-configured confidential-client secret. Required.
KEYCLOAK_CLIENT_SECRET=dev-only-rotate-in-prod
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Valkey (sessions + audit hash-chain head + rate-limit store) ───────
VALKEY_URL=redis://localhost:6379
# In production, also set VALKEY_PASSWORD.

# ─── Audit database (docs/architecture.md §14; ADR-0012, ADR-0013) ──────
# The app's first owned DB. Runtime writes use the least-privilege
# audit_writer role (INSERT + SELECT only); migrations use audit_owner.
# A standalone URL so prod can target a physically separate managed Postgres.
AUDIT_DB_URL=postgres://audit_writer:audit_writer@localhost:5432/audit
AUDIT_DB_OWNER_URL=postgres://audit_owner:audit_owner@localhost:5432/audit
# Redundant durable NDJSON sink for audit events (file on a persistent volume).
AUDIT_LOG_PATH=/var/log/ehrbase-ui/audit.ndjson
# HMAC-SHA256 key for subject pseudonymization (docs/architecture.md §14.4).
# Generate via:  openssl rand -hex 32
AUDIT_PSEUDONYM_SECRET=replace-me-with-openssl-rand-hex-32

# ─── Session timeouts (defaults from docs/architecture.md §5.10) ────────
SESSION_IDLE_TIMEOUT_SECONDS=900       # 15 minutes
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200 # 12 hours

# ─── OpenTelemetry (Milestone 7) ────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ehrbase-ui
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_LOG_LEVEL=warn
