# Environment variables consumed by the ehrbase-ui app and docker-compose.
# Copy to `.env.local` for local development; never commit a real `.env`.
# docs/architecture.md §19.

# ─── Keycloak configuration-as-code (ADR-0036) ──────────────────────────
# The dev stack applies keycloak/config/*.json via keycloak-config-cli on
# every `docker compose up` — realm + clients + the 4 demo users (one per
# realm role; passwords in docs/demo-accounts.md). To run WITHOUT the demo
# users (prod-like), point the keycloak-config service's IMPORT_FILES_LOCATIONS
# at ehrbase-realm.json only. Production never applies ehrbase-users.dev.json.

# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# ─── EHRbase upstream ───────────────────────────────────────────────────
EHRBASE_URL=http://localhost:8080/ehrbase/rest/openehr/v1

# ─── Keycloak (OIDC) ────────────────────────────────────────────────────
# Dual-URL handling (docs/architecture.md §5.4). The browser is redirected to
# the EXTERNAL issuer URL; server-side token + JWKS calls use the INTERNAL one.
# Keycloak's KC_HOSTNAME pins the issuer so validation agrees on both sides.
# In local `pnpm dev` (no container) both point at localhost:8180; in compose
# the internal URL is http://keycloak:8080/realms/ehrbase (set in the ui svc).
KEYCLOAK_ISSUER_URL=http://localhost:8180/realms/ehrbase
KEYCLOAK_INTERNAL_ISSUER_URL=http://localhost:8180/realms/ehrbase
KEYCLOAK_CLIENT_ID=ehrbase-ui
# Replace with the realm-configured confidential-client secret. Required.
KEYCLOAK_CLIENT_SECRET=dev-only-rotate-in-prod
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Valkey (sessions + drafts + rate-limit store) ──────────────────────
VALKEY_URL=redis://localhost:6379
# In production, also set VALKEY_PASSWORD.

# ─── Draft autosave encryption (field-encryption.server.ts — §7.x) ──────
# 32-byte secret; HKDF-derived key encrypts in-progress composition drafts at
# rest in Valkey (XChaCha20-Poly1305). Generate via:  openssl rand -hex 32
DRAFT_ENCRYPTION_SECRET=replace-me-with-openssl-rand-hex-32

# ─── Auth database (docs/architecture.md §5; ADR-0028, ADR-0029) ────────
# Better Auth's user / session / account / verification + admin / org / sso
# plugin tables. Runtime writes use the auth_writer role (full CRUD on the
# Better Auth tables only); migrations use auth_owner.
AUTH_DB_URL=postgres://auth_writer:auth_writer@localhost:5432/auth
AUTH_DB_OWNER_URL=postgres://auth_owner:auth_owner@localhost:5432/auth
# Server-side secret used by Better Auth to sign cookies + tokens. Generate
# via: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32
# Public base URL for the app; Better Auth uses this for callback URLs.
BETTER_AUTH_URL=http://localhost:3000
# SSO plugin: Keycloak OIDC provider config (the Keycloak realm we already
# import). Better Auth fetches the OIDC discovery doc from {issuer}/.well-known.
SSO_KEYCLOAK_PROVIDER_ID=keycloak
SSO_KEYCLOAK_ISSUER=http://localhost:8180/realms/ehrbase
SSO_KEYCLOAK_CLIENT_ID=ehrbase-ui
SSO_KEYCLOAK_CLIENT_SECRET=dev-only-rotate-in-prod

# ─── Demographic provider (docs/architecture.md §M7; ADR-0031, ADR-0033) ─
# Pluggable interface, but 'builtin' (our Postgres VERSIONED_PARTY store) is the
# only provider for now. The external FHIR/HL7v2/PDQ adapter was removed in the
# core refocus; the DemographicProvider interface is retained so a wire adapter
# can be re-added behind a new ADR. Any other value is rejected at startup.
DEMOGRAPHIC_PROVIDER=builtin
# Built-in adapter DB. Runtime writes use the least-privilege demographic_writer
# role (full CRUD on the demographic tables only); migrations use
# demographic_owner. Standalone URL so prod can target a separate managed Postgres.
DEMOGRAPHIC_DB_URL=postgres://demographic_writer:demographic_writer@localhost:5432/demographic
DEMOGRAPHIC_DB_OWNER_URL=postgres://demographic_owner:demographic_owner@localhost:5432/demographic
# The PartyRef namespace placed in EHR_STATUS.subject.external_ref (rule 12).
DEMOGRAPHIC_PARTY_NAMESPACE=demographic
# HMAC-SHA256 key for demographic identifier pseudonymization (rule 12).
# Keeps the national identifier out of the clear in PartyRef hashing.
# Generate via:  openssl rand -hex 32
AUDIT_PSEUDONYM_SECRET=replace-me-with-openssl-rand-hex-32

# ─── Audit — IHE ATNA access trail (docs/architecture.md §14; ADR-0041) ──
# Append-only `audit` DB. Runtime writes use the least-privilege audit_writer
# role (INSERT + SELECT only); migrations use audit_owner. Standalone URL so prod
# can target a separate managed Postgres. The tamper-evidence hash chain +
# retention + cold-store + the syslog forwarder to an external Audit Record
# Repository are deferred hardening (ADR-0041 / CLAUDE.md "Deferred (post-core)").
AUDIT_DB_URL=postgres://audit_writer:audit_writer@localhost:5432/audit
AUDIT_DB_OWNER_URL=postgres://audit_owner:audit_owner@localhost:5432/audit
# Identifies this node in emitted ATNA AuditMessages (AuditSourceIdentification).
ATNA_AUDIT_SOURCE_ID=ehrbase-ui-dev
# Optional enterprise-site id (multi-facility deployments).
# ATNA_ENTERPRISE_SITE_ID=

# ─── External terminology provider (ADR-0034; ADR-0022 Snowstorm default) ─
# Pluggable: 'none' (default — unconfigured: the coded-field picker degrades to a
# plain text input and shows "terminology not configured"), 'snowstorm' (SNOMED CT
# via Snowstorm's FHIR endpoint), or 'generic-fhir' (any FHIR R4 tx server —
# HAPI tx / Ontoserver basic / national terminology server). NOT PHI — no audit.
TERMINOLOGY_PROVIDER=none
# Base URL of the FHIR Terminology Service endpoint (required unless provider=none).
# Dev options:
#   - self-hosted Snowstorm  (docker compose --profile snomed up):  http://localhost:8095/fhir
#   - generic HAPI tx server (docker compose --profile terminology up): http://localhost:8094/fhir
#   - public SNOMED sandbox (zero-setup, read-only intl edition): https://snowstorm.ihtsdotools.org/fhir
TERMINOLOGY_FHIR_BASE=http://localhost:8095/fhir
# generic-fhir only: only R4/R4B implemented in v1.0 (R5/R6 throw at construction).
TERMINOLOGY_FHIR_VERSION=R4
# Optional default display language (BCP-47) for $expand/$lookup results.
TERMINOLOGY_DISPLAY_LANGUAGE=en
# snowstorm only: optional SNOMED edition/version for `system-version`.
TERMINOLOGY_SNOMED_VERSION=
# Optional bearer token for the terminology server.
TERMINOLOGY_TOKEN=

# ─── Session timeouts (defaults from docs/architecture.md §5.10) ────────
SESSION_IDLE_TIMEOUT_SECONDS=900       # 15 minutes
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200 # 12 hours

# Resource attribute. Production reads from CI/build env so each artefact
# is tagged with its build version.
APP_VERSION=dev
